export function lookupEmoji(name: string): string | null {
  if (!name || name.length === 0) {
    return null;
  }
  const value: string | undefined = GITHUB_EMOJI_MAP[name];
  if (value === undefined || value === null) {
    return null;
  }
  return value;
}

export function emojiNames(): string[] {
  return Object.keys(GITHUB_EMOJI_MAP);
}
