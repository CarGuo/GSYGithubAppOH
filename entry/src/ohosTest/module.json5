{
  "module": {
    "name": "entry_test",
    "type": "feature",
    "description": "GSYGithubApp ohosTest module",
    "mainElement": "TestAbility",
    "testRunner": {
      "name": "OpenHarmonyTestRunner",
      "srcPath": "./ets/testrunner/OpenHarmonyTestRunner.ets"
    },
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:test_pages",
    "abilities": [
      {
        "name": "TestAbility",
        "srcEntry": "./ets/testability/TestAbility.ets",
        "description": "GSYGithubApp test ability for hypium",
        "icon": "$media:app_icon",
        "label": "$string:TestAbilityName",
        "exported": true,
        "startWindowIcon": "$media:app_icon",
        "startWindowBackground": "$color:start_window_background",
        "skills": [
          {
            "actions": [
              "action.system.home"
            ],
            "entities": [
              "entity.system.home"
            ]
          }
        ]
      }
    ]
  }
}
